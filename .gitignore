cat > .gitignore <<'EOF'
# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/

# Virtual environments
venv/
env/
.venv/
ENV/

# Environment variables
.env

# OS files
.DS_Store
Thumbs.db

# Raw and processed data
# Do not push large Kaggle data files to GitHub
data/raw/*
data/interim/*
data/processed/*
data/submissions/*

!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/submissions/.gitkeep

# Model files
models/baseline/*
models/tuned/*
models/final_ensemble/*

!models/baseline/.gitkeep
!models/tuned/.gitkeep
!models/final_ensemble/.gitkeep

# Outputs
outputs/figures/*
outputs/oof_predictions/*
outputs/feature_importance/*
outputs/experiment_logs/*

!outputs/figures/.gitkeep
!outputs/oof_predictions/.gitkeep
!outputs/feature_importance/.gitkeep
!outputs/experiment_logs/.gitkeep

# Logs
*.log

# Large ML artifacts
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.ckpt
*.onnx

# Kaggle API token
kaggle.json
EOF